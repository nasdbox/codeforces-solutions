  ios_base::sync_with_stdio(false), cin.tie(nullptr);
  int n; cin >> n;
  if (n&1) {
    cout << 0 << "\n";
    return 0;
  }
  int dp[n+5] = {0};
  for (int i = 2; i <= n; i++) {
    dp[i] = dp[i-2] + 2;
  }

  cout << dp[n] << "\n";
